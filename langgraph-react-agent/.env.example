# Local development configuration. Copy to `.env` and fill in.
# In a deployed Databricks App these values come from the injected service
# principal + the attached Lakebase/serving-endpoint resources instead.

# CLI profile used for local auth (WorkspaceClient + ChatDatabricks).
# NOTE: profile names are case-sensitive in the Databricks CLI.
DATABRICKS_PROFILE=fevm

# --- Lakebase (Autoscaling) --- fill in after provisioning ---
# Endpoint path used to mint the short-lived DB credential (from
# `databricks postgres list-endpoints projects/<id>/branches/<branch>`):
LAKEBASE_ENDPOINT=projects/langgraph-react-agent/branches/production/endpoints/primary
PGHOST=ep-floral-union-d27ga2my.database.us-east-1.cloud.databricks.com
# Locally, PGUSER is your own Postgres role (e.g. your username with dots as hyphens);
# in the deployed app it is the service principal's client id (auto-injected).
PGUSER=<your-postgres-role>
PGDATABASE=databricks_postgres
PGPORT=5432
PGSSLMODE=require

# --- LLM (Foundation Model serving endpoint) ---
LLM_ENDPOINT=databricks-claude-sonnet-4-5

# Optional: override token refresh cadence (seconds); default 1800
# TOKEN_REFRESH_INTERVAL_S=1800
