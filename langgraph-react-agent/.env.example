# Local development configuration. Copy to `.env` and fill in.
# In a deployed Databricks App these values come from the injected service
# principal + the attached Lakebase/serving-endpoint resources instead.

# CLI profile used for local auth (WorkspaceClient + ChatDatabricks)
DATABRICKS_PROFILE=FEVM

# --- Lakebase (Autoscaling) --- fill in after provisioning ---
# Endpoint path used to mint the short-lived DB credential:
LAKEBASE_ENDPOINT=projects/<project-id>/branches/<branch-id>/endpoints/primary
PGHOST=<instance>.database.cloud.databricks.com
PGUSER=<your-user-or-service-principal-client-id>
PGDATABASE=databricks_postgres
PGPORT=5432
PGSSLMODE=require

# --- LLM (Foundation Model serving endpoint) ---
LLM_ENDPOINT=databricks-claude-sonnet-4-5

# Optional: override token refresh cadence (seconds); default 1800
# TOKEN_REFRESH_INTERVAL_S=1800
